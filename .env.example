# PromptGym Configuration

# Server
HOST=0.0.0.0
PORT=7860

# LLM Mode (mock or openai)
LLM_MODE=mock

# Reward Threshold for episode termination
REWARD_THRESHOLD=0.95

# Maximum steps per episode
MAX_STEPS=5

# Enable torch-based reward scorer (requires torch)
USE_TORCH_SCORER=True

# Logging
LOG_FILE=logs/episodes.jsonl
